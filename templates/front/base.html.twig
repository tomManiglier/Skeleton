<!DOCTYPE html>
<html lang="{{ app.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Skeleton{% endblock %}</title>
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    {% include 'components/gtm.html.twig' %}
</head>
<body data-cookie-consent-config-url="{{ path('app_cookie_consent_config') }}">
    {% include 'components/headband.html.twig' %}

    {% block body %}{% endblock %}

    <footer class="site-footer">Skeleton</footer>

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>
